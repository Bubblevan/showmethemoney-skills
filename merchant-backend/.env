# ShowMeTheMoney Pro Merchant Backend Configuration
# Copy this file to .env.local for local overrides (do not commit .env.local)

# =============================================================================
# Server Configuration
# =============================================================================
# Server port (default: 8787)
PORT=8787

# =============================================================================
# StablePay Gateway Configuration
# =============================================================================
# StablePay API Gateway URL
# For production (阿里云): https://ai.wenfu.cn
# For local development: http://127.0.0.1:28080
GATEWAY_BASE_URL=https://ai.wenfu.cn

# StablePay API Key
STABLEPAY_API_KEY=stablepay-dev-key

# =============================================================================
# Skill Configuration (These are used in 402 responses)
# =============================================================================
# Skill DID - The unique identifier for this skill in StablePay
SKILL_DID=did:solana:4p8F5YAJM8fdrNyvWfb3p6XHx8rboFVV3xn279VXo2j7

# Skill name for display
SKILL_NAME=showmethemoney-pro

# Price in the specified currency
PRICE=3.00

# Currency (USDC or USDT)
CURRENCY=USDC

# Message shown to users when payment is required
MESSAGE=Pay to unlock ShowMeTheMoney Pro premium content

# =============================================================================
# Security Configuration
# =============================================================================
# Secret used to generate merchant proofs (CHANGE THIS IN PRODUCTION!)
# This should be a long random string, e.g., generated with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MERCHANT_PROOF_SECRET=replace-this-with-a-long-random-secret-in-production

# =============================================================================
# Debug/Development Options
# =============================================================================
# Enable debug routes (/developer/*, /agent/*) - set to 1 to enable
ENABLE_DEBUG_ROUTES=0

# Internal base URL for debug endpoints (optional)
# INTERNAL_BASE_URL=http://127.0.0.1:28080
